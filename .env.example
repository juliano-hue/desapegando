# Obrigatórios
JWT_SECRET="troque-por-uma-chave-forte"
DATABASE_URL="file:./prisma/dev.db"

# Origens (produção)
# Em produção, a aplicação normalmente roda no mesmo domínio do frontend.
FRONTEND_ORIGIN="http://localhost:5173"
API_PUBLIC_ORIGIN="http://localhost:3002"

# Uploads
# Em produção (ex.: Render), use um diretório persistente, ex.: /var/data/uploads
UPLOAD_DIR="C:/Users/SEU_USUARIO/AppData/Local/Temp/desapegando-uploads"

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
